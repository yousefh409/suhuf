# Suhuf — Root env file (single source of truth)
# Copy to .env and fill in values, then run: ./scripts/sync-env.sh

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend email (optional — waitlist works without it)
RESEND_API_KEY=re_...

# Site URL (used in referral links and emails)
NEXT_PUBLIC_URL=http://localhost:3003

# Email sender (optional)
EMAIL_FROM=suhuf <onboarding@resend.dev>
